{
    "dashboard": {
      "id": null,
      "title": "MCP Server Overview",
      "tags": ["mcp", "steam", "docker"],
      "timezone": "browser",
      "panels": [
        {
          "id": 1,
          "title": "Container CPU Usage",
          "type": "stat",
          "targets": [
            {
              "expr": "rate(container_cpu_usage_seconds_total{name=\"steam-analytics-mcp\"}[5m]) * 100",
              "legendFormat": "CPU %"
            }
          ],
          "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
        },
        {
          "id": 2,
          "title": "Container Memory Usage",
          "type": "stat",
          "targets": [
            {
              "expr": "container_memory_usage_bytes{name=\"steam-analytics-mcp\"} / 1024 / 1024",
              "legendFormat": "Memory MB"
            }
          ],
          "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
        },
        {
          "id": 3,
          "title": "Container Health Status",
          "type": "stat",
          "targets": [
            {
              "expr": "container_last_seen{name=\"steam-analytics-mcp\"}",
              "legendFormat": "Last Seen"
            }
          ],
          "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8}
        }
      ],
      "time": {"from": "now-1h", "to": "now"},
      "refresh": "5s"
    }
}