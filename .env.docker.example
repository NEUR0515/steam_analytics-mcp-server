# Docker Environment Configuration Files

# ================================
# .env.docker (Docker environment variables)
# ================================
# Copy this to .env.docker and customize

# Steam API Configuration
STEAM_API_KEY=your_steam_api_key_here
STEAM_RATE_LIMIT=100
STEAM_BURST_LIMIT=10

# Application Configuration
NODE_ENV=production
LOG_LEVEL=info

# Database Configuration (if using database MCP)
POSTGRES_USER=mcpuser
POSTGRES_PASSWORD=secure_password_here
POSTGRES_DB=mcptools
DATABASE_URL=postgresql://mcpuser:secure_password_here@postgres:5432/mcptools

# Monitoring Configuration
GRAFANA_PASSWORD=admin_password_here

# MCP Configuration
MCP_SERVER_PORT=3000
MCP_GATEWAY_PORT=8080

# Security Configuration
JWT_SECRET=your_jwt_secret_here
API_RATE_LIMIT=1000
